PORT=5000
FRONTEND_ORIGIN=http://localhost:8080

# Optional persistent storage paths. On hosts with ephemeral filesystems,
# point these to a mounted persistent disk or external volume.
# DATA_STORE_DIR=/var/data/eb-chemical
# UPLOADS_DIR=/var/data/eb-chemical/uploads

# Production persistent storage. When these are set, the backend reads/writes
# data from Supabase PostgreSQL instead of store.json, and uploads images to
# Supabase Storage instead of backend/uploads.
# Copy these into backend/.env for local backend development.
# Do not commit the real SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_URL=https://hmugkuhbsqbdbnoqhcsm.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=paste-your-service-role-key-here
# SUPABASE_BUCKET=eb-chemical-uploads

# LAN testing:
# FRONTEND_ORIGIN=http://192.168.56.1:8080
